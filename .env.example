# LLM backend: "cli" (Claude Code / Max aboneligi, API kredisi harcamaz)
#              "api" (Anthropic API, otomatik/olcekli calisma icin)
LLM_BACKEND=cli

# --- CLI backend (LLM_BACKEND=cli) ---
# Claude Code kurulu ve giris yapmis olmali. Kredi harcamaz, Max'ten calisir.
CLI_MODEL=sonnet

# --- API backend (LLM_BACKEND=api) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANALYZER_MODEL=claude-haiku-4-5

# Playwright scraper gorunur pencerede mi calissin? (debug icin false)
HEADLESS=true

# --- Eszamanlilik / dayaniklilik (toplu/olcek islemleri) ---
# Website tarama paraleligi (ag I/O, backend'den bagimsiz). Varsayilan 4.
ENRICH_CONCURRENCY=4
# LLM cagri paraleligi. Bos birak -> api icin 6, cli icin 1 (Max rate-limit).
# LLM_CONCURRENCY=6
# Gecici hatada (rate-limit/timeout/bozuk JSON) yeniden deneme sayisi. Varsayilan 3.
LLM_RETRIES=3

# --- Depolama ---
# "json" (yerel dosya, varsayilan) veya "supabase" (kalici DB)
STORAGE_BACKEND=json

# Supabase (STORAGE_BACKEND=supabase icin). Proje > Settings > API:
#  - SUPABASE_URL      = Project URL
#  - SUPABASE_SERVICE_KEY = service_role key (GIZLI, sadece sunucu tarafi!)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
